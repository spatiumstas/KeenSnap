#!/bin/sh

CONFIG_FILE="/opt/root/KeenSnap/config.conf"
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"
SYSTEM_LD_LIBRARY_PATH="/lib:/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
OPKG_LD_LIBRARY_PATH="/opt/lib:/opt/usr/lib:/lib:/usr/lib"
export LD_LIBRARY_PATH="$OPKG_LD_LIBRARY_PATH"
SCRIPT_VERSION=""
PATH_SNAPD="/opt/etc/ndm/schedule.d/99-keensnap.sh"
REMOTE_VERSION=$(curl -s "https://api.github.com/repos/spatiumstas/keensnap/releases/latest" | grep -Po '"tag_name": "\K.*?(?=")')
datetime=$(date +%Y-%m-%d_%H-%M)
date="backup$datetime"
items=""
statuses=""
(
  case "$1" in
  start)
    if [ -n "$2" ]; then
      SCHEDULE="$2"

      log() {
        local message="$(date '+%Y-%m-%d %H:%M:%S') [INFO] $*"
        echo "$message"
        logger -p notice -t KeenSnap "$*"
      }

      error() {
        local message="$(date '+%Y-%m-%d %H:%M:%S') [ERROR] $*"
        echo "$message"
        logger -p err -t KeenSnap "$*"
      }

      success() {
        local message="$(date '+%Y-%m-%d %H:%M:%S') [SUCCESS] $*"
        echo "$message"
        logger -p notice -t KeenSnap "$*"
      }

      rci_request() {
        local endpoint="$1"
        curl -s "http://localhost:79/rci/$endpoint"
      }

      rci_parse() {
        local command="$1"
        curl -fsS -H "Content-Type: application/json" \
          -d "[{\"parse\":\"$command\"}]" \
          "http://localhost:79/rci/"
      }

      ndmc_cli() {
        LD_LIBRARY_PATH="$SYSTEM_LD_LIBRARY_PATH" ndmc -c "$@"
      }
      
      get_device_info() {
        version_output=$(rci_request "show/version" 2>/dev/null)
        DEVICE=$(echo "$version_output" | grep -o '"device": "[^"]*"' | cut -d'"' -f4 2>/dev/null)
        FW_VERSION=$(echo "$version_output" | grep -o '"release": "[^"]*"' | cut -d'"' -f4 2>/dev/null)
        FW_VERSION_TITLE=$(echo "$version_output" | grep -o '"title": "[^"]*"' | cut -d'"' -f4 2>/dev/null)
        DEVICE_ID=$(echo "$version_output" | grep -o '"hw_id": "[^"]*"' | cut -d'"' -f4 2>/dev/null)

        [ -z "$DEVICE" ] && DEVICE="unknown"
        [ -z "$FW_VERSION" ] && FW_VERSION="unknown"
        [ -z "$FW_VERSION_TITLE" ] && FW_VERSION_TITLE="$DEVICE"
        [ -z "$DEVICE_ID" ] && DEVICE_ID="unknown"
      }

      get_architecture() {
        arch=$(opkg print-architecture | grep -oE 'mips-3|mipsel-3|aarch64-3' | head -n 1)

        case "$arch" in
        "mips-3") echo "mips" ;;
        "mipsel-3") echo "mipsel" ;;
        "aarch64-3") echo "aarch64" ;;
        *) echo "unknown_arch" ;;
        esac
      }

      package_check() {
        package="$1"
        if ! opkg list-installed | grep -q "^$package"; then
          opkg update && opkg install "$package"
        fi
      }

      clean_log() {
        local log_file="$1"
        local max_size=524288

        if [ ! -f $log_file ]; then
          touch $log_file
        fi

        local current_size=$(wc -c <"$log_file")
        if [ $current_size -gt $max_size ]; then
          sed -i '1,100d' "$log_file"
          log "Лог-файл был обрезан на первые 100 строк."
        fi
      }

      curl_with_network() {
        if [ -n "${PROXY_INTERFACE:-}" ] && [ -n "${TG_PROXY:-}" ]; then
          curl --interface "$PROXY_INTERFACE" --proxy "$TG_PROXY" "$@"
        elif [ -n "${PROXY_INTERFACE:-}" ]; then
          curl --interface "$PROXY_INTERFACE" "$@"
        elif [ -n "${TG_PROXY:-}" ]; then
          curl --proxy "$TG_PROXY" "$@"
        else
          curl "$@"
        fi
      }

      json_extract_value() {
        local payload="$1"
        local key="$2"
        echo "$payload" | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -n 1
      }

      execute_telegram_request() {
        local request_type="$1"
        shift
        local response
        local response_body

        case "$request_type" in
          "message")
            local payload="$1"
            local curl_output=$(curl_with_network -s -w "\n%{http_code}" -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" -H "Content-Type: application/json" -d "$payload")
            response=$(echo "$curl_output" | tail -n 1)
            response_body=$(echo "$curl_output" | sed '$d')
            ;;
          "document")
            local chat_id="$1"
            local file_path="$2"
            local caption="$3"
            local topic_id="$4"
            local curl_output=$(curl_with_network -s -w "\n%{http_code}" \
              -F "chat_id=$chat_id" \
              -F "document=@$file_path" \
              -F "caption=$caption" \
              -F "parse_mode=Markdown" \
              ${topic_id:+-F "message_thread_id=$topic_id"} \
              "https://api.telegram.org/bot$BOT_TOKEN/sendDocument")
            response=$(echo "$curl_output" | tail -n 1)
            response_body=$(echo "$curl_output" | sed '$d')
            ;;
        esac

        echo "$response|$response_body"
      }

      send_to_gdrive() {
        local file_path="$1"
        local file_name
        local token_response
        local access_token
        local metadata
        local response
        local file_id

        if [ -z "$GD_CLIENT_ID" ] || [ -z "$GD_CLIENT_SECRET" ] || [ -z "$GD_REFRESH_TOKEN" ]; then
          error "Google Drive не настроен: заполните CLIENT_ID/CLIENT_SECRET/REFRESH_TOKEN"
          return 1
        fi

        token_response=$(curl_with_network -s -X POST "https://oauth2.googleapis.com/token" \
          -d "client_id=$GD_CLIENT_ID" \
          -d "client_secret=$GD_CLIENT_SECRET" \
          -d "refresh_token=$GD_REFRESH_TOKEN" \
          -d "grant_type=refresh_token")
        access_token=$(json_extract_value "$token_response" "access_token")

        if [ -z "$access_token" ]; then
          error "Не удалось получить Google Drive access_token"
          return 1
        fi

        file_name=$(basename "$file_path")
        metadata="{\"name\":\"$file_name\",\"mimeType\":\"application/gzip\""
        if [ -n "$GD_FOLDER_ID" ]; then
          metadata="$metadata,\"parents\":[\"$GD_FOLDER_ID\"]"
        fi
        metadata="$metadata}"

        response=$(curl_with_network -s -X POST "https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart" \
          -H "Authorization: Bearer $access_token" \
          -F "metadata=$metadata;type=application/json" \
          -F "file=@$file_path;type=application/gzip")

        file_id=$(json_extract_value "$response" "id")
        if [ -n "$file_id" ]; then
          success "Архив загружен в Google Drive"
          return 0
        fi

        error "Ошибка загрузки в Google Drive. Ответ: $response"
        return 1
      }

      send_archive_by_method() {
        local report="$1"
        local archive_path="$2"
        local methods="$UPLOAD_METHOD"
        local sent_count=0

        if [ -z "$methods" ]; then
          error "UPLOAD_METHOD не задан, отправка пропущена"
          return 1
        fi

        methods=$(echo "$methods" | tr ',' ' ' | tr ' ' '\n' | sed '/^$/d' | awk '!seen[$0]++')

        for method in $methods; do
          case "$method" in
            Telegram)
              if send_to_telegram "$report" "$archive_path"; then
                sent_count=$((sent_count + 1))
              else
                error "Ошибка отправки в Telegram"
              fi
              ;;
            GDrive)
              if send_to_gdrive "$archive_path"; then
                sent_count=$((sent_count + 1))
              else
                error "Ошибка отправки в Google Drive"
              fi
              ;;
            *)
              error "Неизвестный метод отправки: $method"
              ;;
          esac
        done

        if [ "$sent_count" -eq 0 ]; then
          error "Архив не отправлен ни в один канал"
          return 1
        fi
        return 0
      }

      has_upload_method() {
        local target="$1"
        local methods="$UPLOAD_METHOD"

        [ -z "$methods" ] && return 1

        methods=$(echo "$methods" | tr ',' ' ' | tr ' ' '\n' | sed '/^$/d' | awk '!seen[$0]++')
        echo "$methods" | grep -qx "$target"
      }

      cleanup_old_archives() {
        local old_count=0
        local old_list

        if [ -z "$RETAIN_ARCHIVES_DAYS" ]; then
          return 0
        fi

        if ! echo "$RETAIN_ARCHIVES_DAYS" | grep -Eq '^[0-9]+$'; then
          log "RETAIN_ARCHIVES_DAYS задан некорректно: $RETAIN_ARCHIVES_DAYS. Очистка пропущена"
          return 0
        fi

        if [ "$RETAIN_ARCHIVES_DAYS" -eq 0 ]; then
          log "Очистка старых архивов отключена"
          return 0
        fi

        old_list=$(find "$SELECTED_DRIVE" -maxdepth 1 -type f -name "${DEVICE_ID}_*backup*.tar.gz" -mtime +"$RETAIN_ARCHIVES_DAYS" 2>/dev/null)
        if [ -z "$old_list" ]; then
          return 0
        fi

        log "Удаление старого архива:"
        echo "$old_list"

        for old_file in $old_list; do
          if rm -f "$old_file"; then
            old_count=$((old_count + 1))
          else
            error "Не удалось удалить архив: $old_file"
          fi
        done

        if [ "$old_count" -gt 0 ]; then
          log "Удалено старых архивов: $old_count (хранение: $RETAIN_ARCHIVES_DAYS дней)"
        fi
      }

      send_with_retry() {
        local request_type="$1"
        local success_message="$2"
        local error_prefix="$3"
        shift 3
        local retry_count=0
        local max_retries=3
        local retry_delay=5
        local response
        local response_body
        local result

        while [ $retry_count -lt $max_retries ]; do
          result=$(execute_telegram_request "$request_type" "$@")
          response="${result%%|*}"
          response_body="${result##*|}"

          if [ -z "$response_body" ] && [ "$response" != "200" ]; then
            error "Ошибка отправки в Telegram: Пустой ответ сервера, задайте отдельный интерфейс прокси для подключения"
            return 1
          fi

          if [ "$response" = "200" ] && echo "$response_body" | grep -q '"ok":true'; then
            if [ -n "$success_message" ]; then
              success "$success_message"
            fi
            return 0
          else
            error "${error_prefix} (HTTP $response). Ответ сервера: $response_body"
            retry_count=$((retry_count + 1))
            if [ $retry_count -lt $max_retries ]; then
              log "Повторная попытка отправки... (попытка $retry_count из $max_retries)"
              sleep $retry_delay
            fi
          fi
        done
        error "Все попытки отправки исчерпаны ($max_retries из $max_retries)"
        return 1
      }

      send_to_telegram() {
        if [ -z "$BOT_TOKEN" ] || [ -z "$CHAT_ID" ]; then
          log "Токен бота или ID чата не заданы. Отправка в Telegram пропущена."
          return 1
        fi

        local chat_id="${CHAT_ID%%_*}"
        local topic_id="${CHAT_ID#*_}"
        if [ "$chat_id" = "$CHAT_ID" ]; then
          topic_id=""
        fi

        local caption="$1"
        local file_path="$2"
        local escaped_caption=$(echo "$caption" | sed 's/[][*_`]/\\&/g')

        if [ -z "$file_path" ] || [ ! -f "$file_path" ]; then
          local payload
          if [ -n "$topic_id" ]; then
            payload=$(printf '{"chat_id":%s,"message_thread_id":%s,"parse_mode":"Markdown","text":"%s"}' \
              "$chat_id" "$topic_id" "$escaped_caption")
          else
            payload=$(printf '{"chat_id":%s,"parse_mode":"Markdown","text":"%s"}' \
              "$chat_id" "$escaped_caption")
          fi

          send_with_retry "message" "Сообщение успешно отправлено в Telegram" "Ошибка отправки в Telegram" "$payload"
          return $?
        else
          local max_size=$((49 * 1024 * 1024))
          local archive_size=$(wc -c <"$file_path")

          if [ "$archive_size" -le "$max_size" ]; then
            log "Отправка архива: $file_path"
            
            if send_with_retry "document" "Сообщение успешно отправлено в Telegram" "Ошибка отправки в Telegram" "$chat_id" "$file_path" "$escaped_caption" "$topic_id"; then
              return 0
            else
              return 1
            fi
          else
            package_check "coreutils-split"
            log "Архив превышает 49МБ, разбиваем на части..."
            split -b "$max_size" -d --numeric-suffixes=001 --suffix-length=3 "$file_path" "${file_path}."

            local part_files=""
            local part_number=1
            for part_file in "${file_path}."*; do
              if [[ "$part_file" =~ \.[0-9]{3}$ ]]; then
                part_files="$part_files $part_file"
              fi
            done
            local total_parts=$(echo "$part_files" | wc -w)

            cleanup_parts() {
              for part in $part_files; do
                [ -f "$part" ] && rm -f "$part"
              done
            }

            for part_file in $part_files; do
              local part_caption="[🧩 [Часть $part_number из $total_parts]]"$'\n\n'"$escaped_caption"
              log "Отправка части: $part_file"
              
              if send_with_retry "document" "" "Ошибка отправки части $part_file" "$chat_id" "$part_file" "$part_caption" "$topic_id"; then
                rm -f "$part_file"
              else
                cleanup_parts
                return 1
              fi
              part_number=$((part_number + 1))
            done
            return 0
          fi
        fi
      }

      get_drive_path() {
        local selected_drive="$1"
        local date="$2"
        local device_uuid=""
        local subfolder=""
        local rel_path=""
        local ndmc_path=""

        if [ "$selected_drive" = "/storage" ]; then
          rel_path="$date"
          ndmc_path="storage:$rel_path"
        else
          device_uuid=$(echo "$selected_drive" | awk -F'/' '{print $4}')
          if [ "${selected_drive#*/tmp/mnt/$device_uuid/}" != "$selected_drive" ]; then
            subfolder="${selected_drive#*/tmp/mnt/$device_uuid/}"
            subfolder="${subfolder%/}"
          fi
          if [ -n "$subfolder" ]; then
            rel_path="$subfolder/$date"
          else
            rel_path="$date"
          fi
          ndmc_path="$device_uuid:$rel_path"
        fi
        echo "$ndmc_path|$rel_path"
      }

      backup_startup_config() {
        local success=1
        local item_name="startup-config"

        if [ -n "$SELECTED_DRIVE" ]; then
          log "Бэкап $item_name..."
          local paths_out=$(get_drive_path "$SELECTED_DRIVE" "$date")
          local ndmc_path="${paths_out%%|*}"
          local rel_path="${paths_out##*|}"
          local backup_file="$ndmc_path/${DEVICE_ID}_${FW_VERSION}_$item_name.txt"
          rci_parse "copy $item_name $backup_file" >/dev/null 2>&1
          if [ $? -eq 0 ]; then
            success "$item_name сохранён"
            success=0
          else
            error "Ошибка при сохранении $item_name"
          fi
        fi
        items="$items $item_name"
        statuses="$statuses $success"
      }

      backup_entware() {
        local success=1
        local item_name="Entware"
        package_check "tar"
        if [ -n "$SELECTED_DRIVE" ]; then
          log "Бэкап $item_name..."
          local backup_file="$SELECTED_DRIVE/$date/$(get_architecture)_$item_name.tar.gz"
          tar_output=$(tar cvzf "$backup_file" -C /opt --exclude="$backup_file" . 2>&1)
          log_operation=$(echo "$tar_output" | tail -n 2)

          if echo "$log_operation" | grep -iq "error\|no space left on device"; then
            log "Ошибка при сохранении $item_name:" "$RED"
            echo "$log_operation"
          else
            success "$item_name сохранён"
            success=0
          fi
        fi

        items="$items $item_name"
        statuses="$statuses $success"
      }

      backup_wg_private_key() {
        local success=1
        local item_name="WireGuard-Private-Key"
        package_check "wireguard-tools"
        if [ -n "$SELECTED_DRIVE" ]; then
          log "Бэкап $item_name..."
          local folder_path="$SELECTED_DRIVE/$date"
          local backup_file="$folder_path/$item_name.txt"
          wg show all private-key >"$backup_file"
          if [ $? -eq 0 ]; then
            success "$item_name сохранён"
            success=0
          else
            error "Ошибка при сохранении $item_name"
          fi
          items="$items $item_name"
          statuses="$statuses $success"
        fi
      }

      backup_firmware() {
        local success=1
        local item_name="firmware"
        if [ -n "$SELECTED_DRIVE" ]; then
          log "Бэкап $item_name..."
          local paths_out=$(get_drive_path "$SELECTED_DRIVE" "$date")
          local ndmc_path="${paths_out%%|*}"
          local rel_path="${paths_out##*|}"
          local backup_file="$ndmc_path/${DEVICE_ID}_${FW_VERSION}_$item_name.bin"
          rci_parse "copy flash:/$item_name $backup_file" >/dev/null 2>&1
          if [ $? -eq 0 ]; then
            success "$item_name сохранена"
            success=0
          else
            error "Ошибка при сохранении $item_name"
          fi
        fi
        items="$items $item_name"
        statuses="$statuses $success"
      }

      create_backup_and_send_report() {
        local items=""
        local statuses=""
        mkdir -p "$SELECTED_DRIVE/$date"
        local backup_performed=0

        if [ "$BACKUP_ENTWARE" = "true" ]; then
          backup_entware
          backup_performed=1
        fi

        if [ "$BACKUP_STARTUP_CONFIG" = "true" ]; then
          backup_startup_config
          backup_performed=1
        fi

        if [ "$BACKUP_FIRMWARE" = "true" ]; then
          backup_firmware
          backup_performed=1
        fi

        if [ "$BACKUP_WG_PRIVATE_KEY" = "true" ]; then
          backup_wg_private_key
          backup_performed=1
        fi

        if [ "$backup_performed" -eq 0 ]; then
          log "Ни один из вариантов бэкапа не выбран"
          return 1
        fi

        local archive_path
        if [ -n "$SELECTED_DRIVE" ] && [ -d "$SELECTED_DRIVE/$date" ]; then
          cp "$LOG_FILE" "$SELECTED_DRIVE/$date/backup_log.txt"
          cat >"$SELECTED_DRIVE/$date/backup_meta.info" <<EOF
SCRIPT_VERSION="$SCRIPT_VERSION"
DEVICE="$DEVICE"
DEVICE_ID="$DEVICE_ID"
FW_VERSION="$FW_VERSION"
FW_VERSION_TITLE="$FW_VERSION_TITLE"
DATE="$datetime"
UPLOAD_METHOD="$UPLOAD_METHOD"
EOF
          archive_path="$SELECTED_DRIVE/${DEVICE_ID}_${FW_VERSION}_$date.tar.gz"
          log "Создание архива..."
          tar -czf "$archive_path" -C "$SELECTED_DRIVE" "$date"
          if [ $? -ne 0 ]; then
            error "Ошибка при создании архива"
            send_to_telegram "Ошибка при создании архива" "$SELECTED_DRIVE/$date/backup_log.txt"
            rm -rf "$archive_path"
            return 1
          fi
          success "Архив создан"
        else
          error "Невозможно создать архив: папка с бэкапами не найдена."
          return 1
        fi

        local archive_size=$(wc -c <"$archive_path" | awk '{if ($1 >= 1048576) printf "%.1fМБ", $1/1048576; else if ($1 >= 1024) printf "%.1fКБ", $1/1024; else printf "%dБ", $1}')
        local report="🌐 Бэкап: $DEVICE ($DEVICE_ID)"$'\n'"⚙️ Версия: $FW_VERSION_TITLE"$'\n'"💾 Размер: $archive_size"$'\n'"📅 Дата: $datetime"$'\n\n'
        local i=1
        for item in $items; do
          local status_value=$(echo $statuses | cut -d' ' -f$i)
          if [ "$status_value" -eq 0 ]; then
            report="$report✅ $item"$'\n'
          else
            report="$report❌ $item"$'\n'
          fi
          i=$((i + 1))
        done
        [ -n "$HASHTAG" ] && report="$report"$'\n'"$HASHTAG"

        if send_archive_by_method "$report" "$archive_path"; then
          if [ "$DELETE_LOCAL_ARCHIVE_AFTER_BACKUP" = "true" ]; then
            rm -f "$archive_path"
            log "Архив удалён после отправки"
          else
            log "Архив сохранён: $archive_path"
            cleanup_old_archives
          fi
        else
          error "Отправка не удалась, архив оставлен локально: $archive_path"
        fi
      }

      delete_temp_folder() {
        rm -rf "$SELECTED_DRIVE/$date"
      }

      main() {
        clean_log "$LOG_FILE"
        get_device_info
        log "Запуск скрипта для расписания $SCHEDULE"
        local drive_uuid=$(basename "$SELECTED_DRIVE")
        local device_uuid=$(echo "$SELECTED_DRIVE" | awk -F'/' '{print $4}')
        if [ -z "$SELECTED_DRIVE" ] || ([ "$SELECTED_DRIVE" != "/storage" ] && ! ndmc_cli show media 2>/dev/null | grep -q "uuid: $device_uuid"); then
          drive_name=$(basename "$SELECTED_DRIVE")
          error "Выбранный накопитель $drive_name не подключён"
          if has_upload_method "Telegram"; then
            send_to_telegram "❌ Выбранный накопитель $drive_name не подключён" ""
          fi
          return 1
        fi

        create_backup_and_send_report
        delete_temp_folder
        log "Скрипт завершил работу"
      }

      check_update() {
        if [ "$AUTO_UPDATE" != "true" ]; then
          return 0
        fi

        local local_num remote_num
        local l1 l2 l3 l4 r1 r2 r3 r4

        if [ -z "$SCRIPT_VERSION" ] || [ -z "$REMOTE_VERSION" ]; then
          return 0
        fi

        set -- $(printf '%s' "$SCRIPT_VERSION" | sed 's/[^0-9]/ /g')
        l1=${1:-0}; l2=${2:-0}; l3=${3:-0}; l4=${4:-0}
        local_num=$(( (l1 << 24) + (l2 << 16) + (l3 << 8) + l4 ))

        set -- $(printf '%s' "$REMOTE_VERSION" | sed 's/[^0-9]/ /g')
        r1=${1:-0}; r2=${2:-0}; r3=${3:-0}; r4=${4:-0}
        remote_num=$(( (r1 << 24) + (r2 << 16) + (r3 << 8) + r4 ))

        if [ "$remote_num" -gt "$local_num" ]; then
          log "Доступна новая версия: $REMOTE_VERSION. Обновляюсь..."
          exec keensnap "script_update" "silent"
        fi
      }

      main "$SCHEDULE"
      check_update
    fi
    ;;
  *)
    exit 1
    ;;
  esac
) 2>&1 | tee -a "$LOG_FILE"
